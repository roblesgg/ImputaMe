{
  "name": "imputa-me",
  "version": "1.1.0",
  "description": "imputa.me — registra y consulta tus horas por tarea",
  "main": "main.js",
  "author": "imputa.me",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "jimp": "^0.22.12",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "me.imputa.app",
    "productName": "imputa.me",
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "roblesgg",
        "repo": "ImputaMe"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "afterPack": "build-hooks/afterPack.js",
    "portable": {
      "artifactName": "imputame-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "imputa.me",
      "artifactName": "imputame-setup.exe",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
